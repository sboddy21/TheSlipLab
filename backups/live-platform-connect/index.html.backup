<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Slip Lab</title>
  <style>
    * { box-sizing:border-box; }

    body {
      margin:0;
      background:#040404;
      color:white;
      font-family:Inter,Arial,sans-serif;
    }

    header {
      padding:24px 28px;
      border-bottom:1px solid #1f1f1f;
      display:flex;
      justify-content:space-between;
      align-items:center;
    }

    .brand {
      font-size:26px;
      font-weight:900;
    }

    main {
      padding:32px 28px 70px;
    }

    h1 {
      font-size:44px;
      margin:0 0 12px;
      max-width:850px;
    }

    p {
      color:#aaa;
      font-size:17px;
      line-height:1.5;
      max-width:780px;
      margin-bottom:32px;
    }

    .grid {
      display:grid;
      grid-template-columns:repeat(auto-fill,minmax(320px,1fr));
      gap:20px;
    }

    a {
      display:block;
      text-decoration:none;
      color:white;
      background:#0d0d0d;
      border:2px solid #242424;
      border-radius:22px;
      padding:22px;
      min-height:170px;
    }

    a:hover {
      border-color:#30d158;
    }

    h2 {
      margin:0 0 10px;
      font-size:24px;
    }

    .tag {
      color:#30d158;
      font-weight:800;
      font-size:12px;
      letter-spacing:1px;
      margin-bottom:18px;
    }

    .desc {
      color:#aaa;
      font-size:14px;
      line-height:1.45;
    }

    @media(max-width:768px) {
      header, main {
        padding-left:16px;
        padding-right:16px;
      }

      h1 {
        font-size:32px;
      }

      .grid {
        grid-template-columns:1fr;
      }
    }
  </style>
</head>
<body>
  <header>
    <div class="brand">THE SLIP LAB</div>
    <div>LIVE PLATFORM</div>
  </header>

  <main>
    <h1>Baseball Intelligence Command Hub</h1>
    <p>
      Live leverage, bullpen collapse, HR chain reactions, player intelligence,
      heatmaps, stack environments, and volatility tracking.
    </p>

    <section class="grid">
      <a href="./command-center.html">
        <div class="tag">LIVE TERMINAL</div>
        <h2>Command Center</h2>
        <div class="desc">The main live dashboard for leverage, HR pressure, timelines, and volatility.</div>
      </a>

      <a href="./live-game-center.html">
        <div class="tag">GAME STATE</div>
        <h2>Live Game Center</h2>
        <div class="desc">Game level leverage, bullpen grades, HR environment, and pressure scores.</div>
      </a>

      <a href="./live-heatmap.html">
        <div class="tag">HEATMAP</div>
        <h2>Live Heatmap</h2>
        <div class="desc">Pulsing volatility map for chain reactions and inning explosion risk.</div>
      </a>

      <a href="./bullpen-collapse.html">
        <div class="tag">BULLPEN</div>
        <h2>Bullpen Collapse</h2>
        <div class="desc">Team bullpen danger, collapse grades, fatigue signals, and stack boosts.</div>
      </a>

      <a href="./player-intelligence.html">
        <div class="tag">PLAYERS</div>
        <h2>Player Intelligence</h2>
        <div class="desc">Searchable player profiles with power form, contact floor, matchup IQ, and tags.</div>
      </a>
    </section>
  </main>
</body>
</html>
